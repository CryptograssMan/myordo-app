{
  "name": "myordo-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run clean && eslint . && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "npm run build && vite preview",
    "deploy": "npm run build && wrangler deploy && npm run verify:deploy",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply myordo-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply myordo-db --remote",
    "test": "vitest run",
    "icons": "node scripts/generate-icons.mjs",
    "clean": "rm -rf dist node_modules/.vite node_modules/.tmp",
    "verify:deploy": "node scripts/verify-deploy.mjs",
    "build:fast": "eslint . && tsc -b && vite build"
  },
  "dependencies": {
    "@romcal/calendar.philippines": "^3.0.0-dev.125",
    "hono": "^4.12.31",
    "idb": "^8.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "romcal": "^3.0.0-dev.125"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "sharp": "^0.35.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}